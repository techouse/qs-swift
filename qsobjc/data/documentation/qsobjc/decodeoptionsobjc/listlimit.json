{"metadata":{"role":"symbol","title":"listLimit","roleHeading":"Instance Property","externalID":"c:@M@QsObjC@objc(cs)QsDecodeOptions(py)listLimit","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"listLimit","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"symbolKind":"property","modules":[{"name":"QsObjC"}]},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"listLimit","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The limit is cumulative across duplicate keys, flat comma-separated values, and list"},{"type":"text","text":" "},{"type":"text","text":"merges. A result with exactly "},{"type":"codeVoice","code":"listLimit"},{"type":"text","text":" elements remains a list; growing past it"},{"type":"text","text":" "},{"type":"text","text":"becomes a numeric-keyed dictionary, or throws when "},{"type":"codeVoice","code":"throwOnLimitExceeded"},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A negative limit treats every list construction or merge that reaches limit enforcement"},{"type":"text","text":" "},{"type":"text","text":"as exceeded. Parser-recognized empty lists can still be preserved by "},{"type":"codeVoice","code":"allowEmptyLists"},{"type":"text","text":" "},{"type":"text","text":"because they bypass list construction."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Comma values written with "},{"type":"codeVoice","code":"[]="},{"type":"text","text":" are nested groups: each complete comma group counts as"},{"type":"text","text":" "},{"type":"text","text":"one outer list element, regardless of how many values the group contains. Numeric"},{"type":"text","text":" "},{"type":"text","text":"bracket indices at or above the limit are represented as dictionary keys."}]}]}],"hierarchy":{"paths":[["doc:\/\/QsObjC\/documentation\/QsObjC","doc:\/\/QsObjC\/documentation\/QsObjC\/DecodeOptionsObjC"]]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/QsObjC\/documentation\/QsObjC\/DecodeOptionsObjC\/listLimit"},"abstract":[{"type":"text","text":"Maximum list size and numeric-index threshold used while decoding."}],"variants":[{"paths":["\/documentation\/qsobjc\/decodeoptionsobjc\/listlimit"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://QsObjC/documentation/QsObjC/DecodeOptionsObjC":{"navigatorTitle":[{"text":"DecodeOptionsObjC","kind":"identifier"}],"role":"symbol","url":"\/documentation\/qsobjc\/decodeoptionsobjc","title":"DecodeOptionsObjC","abstract":[{"type":"text","text":"Objective-C wrapper for "},{"type":"codeVoice","code":"QsSwift.DecodeOptions"},{"type":"text","text":"."}],"identifier":"doc:\/\/QsObjC\/documentation\/QsObjC\/DecodeOptionsObjC","kind":"symbol","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DecodeOptionsObjC","kind":"identifier"}]},"doc://QsObjC/documentation/QsObjC":{"role":"collection","identifier":"doc:\/\/QsObjC\/documentation\/QsObjC","type":"topic","abstract":[],"url":"\/documentation\/qsobjc","kind":"symbol","title":"QsObjC"},"doc://QsObjC/documentation/QsObjC/DecodeOptionsObjC/listLimit":{"role":"symbol","abstract":[{"type":"text","text":"Maximum list size and numeric-index threshold used while decoding."}],"kind":"symbol","type":"topic","identifier":"doc:\/\/QsObjC\/documentation\/QsObjC\/DecodeOptionsObjC\/listLimit","title":"listLimit","url":"\/documentation\/qsobjc\/decodeopti